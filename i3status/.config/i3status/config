# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!
# Font for Arch Linux logo: https://aur.archlinux.org/packages/ttf-nerd-fonts-symbols/

general {
    output_format = "i3bar"
    colors = true
    color_good = "#A3BE8C"
    color_degraded = "#8FBCBB"
    color_bad = "#4C566A"
    interval = 5
}

order += "ipv6"
order += "ethernet _first_"
order += "wireless _first_"
order += "run_watch vpn"
order += "read_file updates"
order += "battery all"
order += "disk /"
order += "disk /drv"
order += "volume master"
order += "load"
order += "memory"
# order += "tztime local"
order += "tztime foreign"

ipv6 {
    format_up = "🌐IPv6: %ip"
    format_down = "🌐no IPv6"
}

ethernet _first_ {
    format_up = "🔌E:%ip (%speed)"
    format_down = "🔌E:down"
}

wireless _first_ {
    format_up = "📶W:%ip"
    format_down = "📶W:down"
}

run_watch vpn {
    format = "🛡️V:%status"
    format_down = "🛡️V:no"
    pidfile = "/home/orhun/.config/vortix/run/do.pid"
}

read_file updates {
    format = "📦U:%content"
    format_bad = "📦U:-"
    path = "/var/local/updates/count"
}

battery all {
    status_chr = "⚡"
    status_bat = "🔋"
    status_unk = "❓"
    status_idle = "🔌"
    status_full = "💯"
    format = "%status%percentage %remaining"
    last_full_capacity = true
}

volume master {
    device = "default"
    mixer = "Master"
    mixer_idx = 0
    format = "🔊%volume"
}

disk "/" {
    format = "💾/:%avail"
}

disk "/drv" {
    format = "💽/drv:%avail"
}

load {
    format = "🧮%5min"
}

memory {
    format = "🧠%used/%available"
    threshold_degraded = "1G"
    format_degraded = "🧠%available"
}

tztime local {
    timezone = "Asia/Istanbul"
    format = "🇹🇷:%d-%m-%Y %H:%M:%S "
}

tztime foreign {
    format = "%d-%m-%Y %H:%M:%S "
    timezone = "Europe/Berlin"
}
