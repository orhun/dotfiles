<keymap version="1" name="dotfiles" parent="Default for XWin">
  <action id="ActivateTerminalToolWindow">
    <keyboard-shortcut first-keystroke="alt f12" />
    <keyboard-shortcut first-keystroke="ctrl j" />
  </action>
  <action id="EditorDown">
    <keyboard-shortcut first-keystroke="ctrl n" />
  </action>
  <action id="EditorUp">
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
  <action id="InsertLiveTemplate" />
  <action id="IntroduceVariable" />
  <action id="Run">
    <keyboard-shortcut first-keystroke="shift f10" />
    <keyboard-shortcut first-keystroke="shift caps_lock" />
  </action>
  <action id="Terminal.Paste">
    <keyboard-shortcut first-keystroke="ctrl v" />
    <keyboard-shortcut first-keystroke="shift insert" />
    <keyboard-shortcut first-keystroke="shift ctrl v" />
    <keyboard-shortcut first-keystroke="ctrl alt v" />
  </action>
</keymap>
